# WebSocket — usado apenas em `next dev` (getWebSocketUrl).
# Fora de development o URL é fixo: RAILWAY_WS_URL em lib/ws-config.ts.
#
# Local (default em `next dev` já é ws://localhost:8085 se não definires isto):
# NEXT_PUBLIC_WS_URL=ws://localhost:8085
#
# Outro host na rede (ex. telemóvel): usa o IP da máquina onde corre `pnpm run ws:server`
# NEXT_PUBLIC_WS_URL=ws://192.168.1.10:8085
#
# Para apontar next dev para o Railway em vez do local:
# NEXT_PUBLIC_WS_URL=wss://teu-servico.up.railway.app

# Opcional: no consola do browser, logs [ws:frame] com hasReplyTo por mensagem
# NEXT_PUBLIC_WS_DEBUG=1
